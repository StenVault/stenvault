{
    "name": "@stenvault/shared",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "types": "./src/index.ts"
        },
        "./types": {
            "import": "./src/types.ts",
            "types": "./src/types.ts"
        },
        "./const": {
            "import": "./src/const.ts",
            "types": "./src/const.ts"
        },
        "./utils": {
            "import": "./src/utils/index.ts",
            "types": "./src/utils/index.ts"
        },
        "./platform": {
            "import": "./src/platform/index.ts",
            "types": "./src/platform/index.ts"
        },
        "./platform/crypto": {
            "import": "./src/platform/crypto/index.ts",
            "types": "./src/platform/crypto/index.ts"
        },
        "./core": {
            "import": "./src/core/index.ts",
            "types": "./src/core/index.ts"
        },
        "./core/transfer": {
            "import": "./src/core/transfer/index.ts",
            "types": "./src/core/transfer/index.ts"
        },
        "./errors": {
            "import": "./src/errors/index.ts",
            "types": "./src/errors/index.ts"
        },
        "./ui/*": {
            "import": "./src/ui/*.tsx",
            "types": "./src/ui/*.tsx"
        },
        "./lib/*": {
            "import": "./src/lib/*.ts",
            "types": "./src/lib/*.ts"
        },
        "./hooks/*": {
            "import": "./src/hooks/*.ts",
            "types": "./src/hooks/*.ts"
        },
        "./config/*": {
            "import": "./src/config/*.ts",
            "types": "./src/config/*.ts"
        },
        "./styles/*": "./src/styles/*"
    },
    "dependencies": {
        "@stenvault/aead-stream": "workspace:*",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.3.1",
        "zod": "^4.1.12"
    },
    "peerDependencies": {
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-progress": "^1.1.7",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-tooltip": "^1.2.8",
        "class-variance-authority": "^0.7.1",
        "framer-motion": "^12.23.22",
        "lucide-react": "^0.453.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "sonner": "^2.0.7"
    },
    "devDependencies": {
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-progress": "^1.1.7",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "framer-motion": "^12.23.22",
        "@types/node": "^22.0.0",
        "@types/react": "^19.1.16",
        "@types/react-dom": "^19.1.9",
        "class-variance-authority": "^0.7.1",
        "lucide-react": "^0.453.0",
        "sonner": "^2.0.7",
        "typescript": "5.9.3"
    }
}