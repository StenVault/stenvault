{
    "name": "@stenvault/api-types",
    "version": "1.0.0",
    "private": true,
    "description": "Type-only exports from StenVault API for mobile and external clients",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "types": "./src/index.ts"
        },
        "./p2p": {
            "import": "./src/p2p.ts",
            "types": "./src/p2p.ts"
        },
        "./chat": {
            "import": "./src/chat.ts",
            "types": "./src/chat.ts"
        },
        "./files": {
            "import": "./src/files.ts",
            "types": "./src/files.ts"
        },
        "./auth": {
            "import": "./src/auth.ts",
            "types": "./src/auth.ts"
        }
    },
    "dependencies": {
        "@stenvault/shared": "workspace:*",
        "@trpc/server": "^11.8.0"
    },
    "devDependencies": {
        "typescript": "^5.9.2",
        "zod": "^3.25.0"
    }
}